# Environment
NODE_ENV=dev

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token   # for Socket Mode
SLACK_ALERT_CHANNEL=C012AB3CD         # channel ID for Alertmanager alerts
SLACK_ONCALL_USERS=U012AB3CD,U098ZY7WX  # comma-separated Slack user IDs
PORT=3000

# LLM Provider: claude | openai-compatible
LLM_PROVIDER=claude

# Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-opus-4-5

# Private OpenAI-compatible LLM (optional)
# LLM_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_BASE_URL=http://your-llm-server/v1
# OPENAI_COMPATIBLE_API_KEY=your-api-key
# OPENAI_COMPATIBLE_MODEL=your-model-name

# MCP Server
# Transport: stdio | http
MCP_TRANSPORT=stdio
MCP_STDIO_COMMAND=node
MCP_STDIO_ARGS=../devops-mcp-server/dist/index.js
# MCP_HTTP_URL=http://localhost:3001/mcp
