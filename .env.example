# Environment
NODE_ENV=dev

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token   # for Socket Mode
SLACK_ALERT_CHANNEL=C012AB3CD         # channel ID for Alertmanager alerts
SLACK_ONCALL_USERS=U012AB3CD,U098ZY7WX  # comma-separated Slack user IDs
PORT=3000

# LLM Provider: claude | openai-compatible
LLM_PROVIDER=claude

# Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-opus-4-5

# Private LLM via SQS (event-driven, for strict private network)
# LLM_PROVIDER=private-llm
# AWS_REGION=ap-southeast-1
# SQS_REQUEST_QUEUE_NAME=llm-request.fifo
# SQS_RESPONSE_QUEUE_NAME=llm-response.fifo
# SQS_LLM_TIMEOUT_SECONDS=120
# SQS_POLL_WAIT_SECONDS=10
#
# AWS credentials — only needed for local dev, not required when using IRSA on EKS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # optional, for temporary credentials
# OPENAI_COMPATIBLE_BASE_URL=http://your-llm-server/v1
# OPENAI_COMPATIBLE_API_KEY=your-api-key
# OPENAI_COMPATIBLE_MODEL=your-model-name

# MCP Server
# Transport: stdio | http
MCP_TRANSPORT=stdio
MCP_STDIO_COMMAND=node
MCP_STDIO_ARGS=../devops-mcp-server/dist/index.js
# MCP_HTTP_URL=http://localhost:3001/mcp
# Per-tool-call timeout in seconds (a hung MCP server/upstream can't stall an investigation)
# MCP_TOOL_TIMEOUT_SECONDS=45

# Wall-clock budget per investigation in seconds (bounds how long a concurrency slot is held)
# INVESTIGATION_TIMEOUT_SECONDS=300

# Conversation Memory
# MEMORY_BACKEND: inmemory (default, lost on restart) | redis (persistent)
MEMORY_BACKEND=inmemory

# Redis — required only when MEMORY_BACKEND=redis
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_USERNAME=default
# REDIS_PASSWORD=your-redis-password
# REDIS_TLS=false

# Concurrency
# MAX_CONCURRENT_INVESTIGATIONS=5

# Log level: error | warn | info | http | debug (default: debug in dev, info in prod)
# LOG_LEVEL=info

# AWS Auth Mode: iam-anywhere | irsa | env | instance-profile (default: iam-anywhere)
# AWS_AUTH_MODE=irsa
#
# Required only for iam-anywhere:
# AWS_TRUST_ANCHOR_ARN=arn:aws:rolesanywhere:...
# AWS_ROLESANYWHERE_PROFILE_ARN=arn:aws:rolesanywhere:...
# AWS_ROLE_ARN=arn:aws:iam::123456789:role/your-role
# CERT_PATH=/certs/tls.crt
# CERT_KEY_PATH=/certs/tls.key
